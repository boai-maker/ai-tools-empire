# ============================================================
# AI Tools Empire - Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Anthropic (Claude API) ---
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Email: Resend (preferred) ---
# Get from: https://resend.com/ (free tier: 3000 emails/mo)
# If set, Resend is used automatically. Leave blank to use Gmail SMTP below.
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=newsletter@yourdomain.com
FROM_NAME=AI Tools Weekly

# --- Email: Gmail SMTP (fallback, no account needed) ---
# Use your Gmail address + an App Password (NOT your login password).
# Enable App Passwords: myaccount.google.com/apppasswords (requires 2FA)
# If RESEND_API_KEY is blank, Gmail SMTP is used automatically.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# --- Twitter/X API (social automation) ---
# Get from: https://developer.twitter.com/
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_token_secret

# --- Site Config ---
SITE_NAME=AI Tools Weekly
SITE_URL=https://your-domain.com
SITE_TAGLINE=The #1 Resource for AI Tool Reviews, Comparisons & Deals

# --- Admin ---
ADMIN_PASSWORD=change_this_password
SECRET_KEY=generate_a_long_random_string_here

# --- Affiliate Tracking ---
# Your unique IDs for each affiliate program
# Jasper: https://www.jasper.ai/affiliates
JASPER_AFFILIATE_ID=your_id
# Copy.ai: https://www.copy.ai/affiliate-program
COPYAI_AFFILIATE_ID=your_id
# Writesonic: https://writesonic.com/affiliates
WRITESONIC_AFFILIATE_ID=your_id
# Surfer SEO: https://surferseo.com/affiliate/
SURFER_AFFILIATE_ID=your_id
# Semrush: https://www.semrush.com/partner/
SEMRUSH_AFFILIATE_ID=your_id
# Pictory: https://pictory.ai/affiliates
PICTORY_AFFILIATE_ID=your_id
# InVideo: https://invideo.io/affiliate-program/
INVIDEO_AFFILIATE_ID=your_id
# Murf AI: https://murf.ai/affiliate-program
MURF_AFFILIATE_ID=your_id
# ElevenLabs: https://elevenlabs.io/affiliates
